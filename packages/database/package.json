{
  "name": "@tracework/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./schema": {
      "types": "./src/schema/index.ts",
      "default": "./src/schema/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "node -e \"const fs=require('node:fs'); fs.rmSync('dist',{recursive:true,force:true}); fs.rmSync('.turbo',{recursive:true,force:true})\"",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "demo:reset": "tsx scripts/demo-reset.ts",
    "backup": "tsx scripts/backup.ts",
    "restore": "tsx scripts/restore.ts",
    "recovery": "tsx scripts/recovery.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests/schema.structure.test.ts",
    "test:integration": "vitest run tests/postgres.integration.test.ts"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "pg": "8.22.0"
  },
  "devDependencies": {
    "@types/pg": "8.18.0",
    "drizzle-kit": "0.31.10",
    "tsx": "4.21.0",
    "vitest": "4.1.10"
  }
}
