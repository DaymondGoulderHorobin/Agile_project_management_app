{
  "name": "@tracework/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "bin": {
    "tracework-runner": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsx watch src/cli.ts fixture",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --passWithNoTests",
    "recovery": "tsx src/cli.ts recovery"
  },
  "dependencies": {
    "@openai/codex-sdk": "0.145.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
