# Runtime
NODE_ENV=development
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000
API_PORT=4000
WORKER_CONCURRENCY=4

# PostgreSQL (authoritative state)
DATABASE_URL=postgresql://tracework:tracework@localhost:5432/tracework
DATABASE_APPLICATION_URL=postgresql://tracework_app:tracework_app@localhost:5432/tracework
DATABASE_POOL_MAX=10

# Redis and BullMQ
REDIS_URL=redis://localhost:6379

# S3-compatible storage / MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=tracework
S3_ACCESS_KEY_ID=tracework
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=true

# Better Auth. Generate secrets locally; never commit real values.
BETTER_AUTH_URL=http://localhost:4000/api/auth
BETTER_AUTH_SECRET=replace-with-at-least-32-random-bytes
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
BETTER_AUTH_MAGIC_LINK_TTL_SECONDS=300
HIGH_ASSURANCE_REAUTH_TTL_SECONDS=900

# Email. Mailpit is the local default; production uses any SMTP server.
SMTP_URL=smtp://localhost:1025
SMTP_FROM=Tracework <noreply@localhost>

# General AI assistance. The deterministic fixture is safe without credentials.
AI_PROVIDER=fixture
OPENAI_API_KEY=
OPENAI_MODEL_BALANCED=gpt-5.6-terra
OPENAI_MODEL_QUALITY=gpt-5.6-sol
OPENAI_STORE_RESPONSES=false

# GitHub integration. The fixture adapter is used without credentials.
REPOSITORY_PROVIDER=fixture
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Runner. `fixture` is deterministic; `docker` enforces a local container boundary.
RUNNER_PROVIDER=fixture
RUNNER_CAPABILITY_TTL_SECONDS=120
RUNNER_GRACEFUL_SHUTDOWN_SECONDS=30
RUNNER_GRACEFUL_SHUTDOWN_MIN_SECONDS=5
RUNNER_GRACEFUL_SHUTDOWN_MAX_SECONDS=120
RUNNER_NETWORK_DEFAULT=deny
RUNNER_WORKSPACE_ROOT=.local/runner-workspaces

# Demo-only deterministic tenant. Reset commands require this exact identifier.
DEMO_ORGANISATION_SLUG=harbour-product-studio-demo
DEMO_FIXTURE_REPOSITORY=.local/demo-repository
